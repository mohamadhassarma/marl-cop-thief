# LLM Provider API Key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# MCP Server Auth Tokens
COP_MCP_TOKEN=your-cop-mcp-token-here
THIEF_MCP_TOKEN=your-thief-mcp-token-here

# MCP Server URLs (local dev)
COP_MCP_URL=http://localhost:8001
THIEF_MCP_URL=http://localhost:8002

# Gmail OAuth (for automated reporting)
GMAIL_TOKEN_PATH=config/gmail_token.json
GMAIL_CREDENTIALS_PATH=config/gmail_credentials.json

# Game mode: local | cloud
DEPLOYMENT_MODE=local
